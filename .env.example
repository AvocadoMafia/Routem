# =============================================================================
# Routem 環境変数テンプレート
# =============================================================================
# このファイルは git 管理対象（.gitignore で明示的に除外から除いている）。
# 実値は `.env`（ローカル開発用）または `.env.production`（本番用）にコピーして記入する。
#
# 原則:
#  - 環境判定は `NODE_ENV` 1本（development / production）
#  - 自サイトURLは `NEXT_PUBLIC_SITE_URL` に一本化（OAuth/CORS/共有URL）
#  - `NEXT_PUBLIC_*` は Next.js がビルド時にクライアントバンドルへインライン化する。
#    本番 Docker ビルドでは docker-compose-prod.yml の build.args 経由で渡す
#    （runtime container env では反映されない）。
# =============================================================================


# -----------------------------------------------------------------------------
# サイトのベースURL（末尾スラッシュなし）
#   OAuth/メール認証のリダイレクト先 (`${NEXT_PUBLIC_SITE_URL}/auth/callback`) や
#   CORS 判定、共有URL生成などあらゆる「自サイト完全URL」用途で参照する。
#   dev  : http://localhost:3000
#   prod : https://routem.net
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Supabase (Auth / Storage)
#   - NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY は
#     クライアントからも参照するため NEXT_PUBLIC_ が付く（漏れて良い公開値）。
#   - SUPABASE_SERVICE_ROLE_KEY は絶対に NEXT_PUBLIC_ を付けない（漏洩は致命）。
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# 外部 API キー
# -----------------------------------------------------------------------------
# Mapbox (クライアント Mapbox GL / Search, サーバ geocode API 両方で使用)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Cloudflare Turnstile（ログイン/サインアップの Bot 対策）。空でも UI は壊れない
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# OpenExchangeRates（scripts/updateExchangeRates.ts 用）。未設定時はスクリプトが失敗する
OPENEXCHANGERATES_URL=https://openexchangerates.org/api/latest.json?app_id=YOUR_APP_ID


# -----------------------------------------------------------------------------
# Database (Postgres)
#   dev  : docker-compose.yml の postgres サービス（host port 5432）
#   prod : docker-compose-prod.yml の内部ネットワーク経由で @postgres:5432
# -----------------------------------------------------------------------------
POSTGRES_USER=routem
POSTGRES_PASSWORD=routem
POSTGRES_DB=routem
DATABASE_URL=postgresql://routem:routem@localhost:5432/routem


# -----------------------------------------------------------------------------
# Redis / Meilisearch / LibreTranslate
#   dev  : ホストから localhost:<port> で接続
#   prod : docker-compose-prod.yml が compose 内サービス名で上書きする
#          （REDIS_URL=redis://redis:6379 等）
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_APIKEY=
LIBRETRANSLATE_URL=http://localhost:5050/


# -----------------------------------------------------------------------------
# Object Storage (dev: MinIO)
#   本番は OCI Object Storage を使うので .env.production で OCI_* を埋める。
#   ここで設定するのは MinIO の接続情報のみ。
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
