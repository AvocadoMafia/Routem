# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.env
.env.local
.processe.env

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# テンプレート / 値なしの example だけは共有する
!.env.example

# vercel（過去に vercel 運用していた際の残骸対策。ローカルに .vercel/ があっても誤コミットしない）
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/prisma/migrations/

# Playwright (E2E テスト関連は別 PR で整備中)
.playwright-mcp/
playwright.config.ts
playwright-report/
test-results/

# ローカルの docker-compose override（個人ごとの port 変更等を入れるための場所）
docker-compose.override.yml

# Playwright / smoke テストの screenshot 出力（root に出てくる *.png を全除外）
/*.png

# .claude/ 配下のローカル一時ファイル / セッション固有ファイル / D2 作業固有ファイル
.claude/scheduled_tasks.lock
.claude/screenshots/
.claude/settings.local.json
.claude/tester2-auth-plan.md
.claude/prisma-import-files.md
.claude/phase-d2-plan.md
.claude/phase-d2-checklist.md
.claude/phase-d2-preflight.sh
.claude/phase-d2-tag-and-rollback.sh
