  "about": {
    "planTogether": "Plan Together,",
    "travelSmarter": "Travel Smarter.",
    "heroQuote": "\"I want to travel, but planning is a hassle\" - We want to answer this voice.",
    "languages": "4 Languages",
    "languagesDesc": "Japanese, English, Korean & Chinese",
    "platforms": "Platforms",
    "mapSns": "Map x SNS",
    "connectPosts": "Connect through posts",
    "aboutRoutem": "About Routem",
    "aboutDescription": "Travel lovers post amazing routes on social media and blogs every day. However, these are scattered and cannot be used directly as travel plans. Routem bridges this gap.",
    "problemTitle": "Travel should be fun, but planning becomes a chore.",
    "problemDesc1": "Planning a trip requires a lot of effort. Research destinations, select spots, check transportation, consider the order, estimate time. For many people, what should be an enjoyable trip becomes tedious at the planning stage.",
    "problemDesc2": "Meanwhile, travel enthusiasts post wonderful routes on social media and blogs every day. However, this information is scattered and cannot be used directly as \"your own travel plan.\"",
    "editorsNote": "Editor's note",
    "statPercent": "72%",
    "statDesc": "Percentage of travelers who have felt \"hassle\" in travel planning (our survey). High planning hurdles are taking away opportunities to depart.",
    "solution": "Solution",
    "solutionTitle": "From \"creating from scratch\" to \"choosing and using.\"",
    "featureTitle": "Turning travel \"hassle\" into \"fun.\"",
    "featureDesc": "Routem bridges the gap between the hassle of planning and the joy of travel. Borrow someone's real route and make it your own.",
    "routeCreation": "Route Creation",
    "routeCreationTitle": "Create on the map, share on the map.",
    "routeCreationDesc": "Create routes by connecting location information on the map. Visualize paths and transportation, attach photos and thoughts to each spot. Authors can also add detailed descriptions like a blog.",
    "smartSearch": "Smart Search",
    "smartSearchTitle": "Find it quickly by travel conditions.",
    "smartSearchDesc": "In addition to general text search, our unique search filters by purpose, season, location, duration, budget, and situation, quickly turning your vague ideas into concrete plans.",
    "copyEdit": "Copy & Edit",
    "copyEditTitle": "Arrange and pass it to someone else.",
    "copyEditDesc": "Copy other users' routes with one tap and use them as your own plan. Use it as is, swap spots to arrange, or re-share after editing - it's all OK.",
    "community": "Community",
    "communityTitle": "A place where travel lovers connect.",
    "communityDesc": "Interact with other travelers through comments and likes on routes. Follow your favorite posters and check their new routes. Model courses from tourism associations and DMOs can also be posted as interactive routes on the map.",
    "stepsTitle": "4 steps to start your journey.",
    "step1": "Step 01",
    "step1Title": "Search routes",
    "step1Desc": "Search by destination or conditions like \"Kyoto 2-day girls trip\". Candidate routes appear on the map.",
    "step2": "Step 02",
    "step2Title": "Check on the map",
    "step2Desc": "Check routes on the map. Compare transportation, duration, photos, and impressions.",
    "step3": "Step 03",
    "step3Title": "Copy and arrange",
    "step3Desc": "Copy a route with one tap. Swap spots to your liking and complete your plan.",
    "step4": "Step 04",
    "step4Title": "Go on your trip",
    "step4Desc": "All that's left is to depart. After enjoying your trip, post your own route for the next traveler.",
    "readerA": "Reader A",
    "reader20s": "20s",
    "reader20sTitle": "Travel lovers in their 20s-30s who find planning a hassle",
